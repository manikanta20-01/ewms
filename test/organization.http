###

DELETE {{host}}/odata/v4/organization/Departments(44444444-4444-4444-4444-444444444444)

############################################################
# DEPARTMENT HR
############################################################

###

GET {{host}}/odata/v4/organization/DepartmentHRs

###

GET {{host}}/odata/v4/organization/DepartmentHRs(55555555-5555-5555-5555-555555555555)

###

POST {{host}}/odata/v4/organization/DepartmentHRs
Content-Type: application/json

{
    "department_ID":"44444444-4444-4444-4444-444444444444",
    "employee_ID":"10000000-0000-0000-0000-000000000001"
}

###

PATCH {{host}}/odata/v4/organization/DepartmentHRs(55555555-5555-5555-5555-555555555555)
Content-Type: application/json

{
    "employee_ID":"10000000-0000-0000-0000-000000000002"
}

###

DELETE {{host}}/odata/v4/organization/DepartmentHRs(55555555-5555-5555-5555-555555555555)

############################################################
# EXPAND TESTS
############################################################

###

GET {{host}}/odata/v4/organization/Companies?$expand=businessUnits

###

GET {{host}}/odata/v4/organization/BusinessUnits?$expand=company

###

GET {{host}}/odata/v4/organization/Departments?$expand=location,businessUnit

###

GET {{host}}/odata/v4/organization/DepartmentHRs?$expand=department