@host = http://localhost:4004

############################################################
# ORGANIZATION SERVICE
############################################################

############################################################
# COMPANY
############################################################

### Get All Companies
GET {{host}}/odata/v4/organization/Companies

###

### Get Company By ID
# Replace ID after creating a company
GET {{host}}/odata/v4/organization/Companies(11111111-1111-1111-1111-111111111111)

###

### Create Company
POST {{host}}/odata/v4/organization/Companies
Content-Type: application/json

{
    "companyName":"Manikanta Technologies Pvt Ltd",
    "email":"info@ewms.com",
    "phone":"+919876543210",
    "website":"https://Manikanta.com",
    "currency":"INR",
    "registrationNo":"998525990088775567677"
}

###

### Update Company
PATCH {{host}}/odata/v4/organization/Companies(11111111-1111-1111-1111-111111111111)
Content-Type: application/json

{
    "phone":"+919999999999"
}

###

### Delete Company
DELETE {{host}}/odata/v4/organization/Companies(11111111-1111-1111-1111-111111111111)

############################################################
# BUSINESS UNIT
############################################################

###

GET {{host}}/odata/v4/organization/BusinessUnits

###

GET {{host}}/odata/v4/organization/BusinessUnits(bbbbbbbb-2222-2222-2222-222222222222)

###

POST {{host}}/odata/v4/organization/BusinessUnits
Content-Type: application/json

{
    "company_ID":"11111111-1111-1111-1111-111111111111",
    "name":"Technology"
}

###

PATCH {{host}}/odata/v4/organization/BusinessUnits(22222222-2222-2222-2222-222222222222)
Content-Type: application/json

{
    "name":"Technology Division"
}

###

DELETE {{host}}/odata/v4/organization/BusinessUnits(22222222-2222-2222-2222-222222222222)

############################################################
# LOCATION
############################################################

###

GET {{host}}/odata/v4/organization/Locations

###

GET {{host}}/odata/v4/organization/Locations(33333333-3333-3333-3333-333333333333)

###

POST {{host}}/odata/v4/organization/Locations
Content-Type: application/json

{
    "businessUnit_ID":"22222222-2222-2222-2222-222222222222",
    "name":"Hyderabad",
    "city":"Hyderabad",
    "state":"Telangana",
    "country":"India"
}

###

PATCH {{host}}/odata/v4/organization/Locations(33333333-3333-3333-3333-333333333333)
Content-Type: application/json

{
    "city":"Bangalore"
}

###

DELETE {{host}}/odata/v4/organization/Locations(33333333-3333-3333-3333-333333333333)

