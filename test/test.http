    "accountType":"Salary",
    "currency":"INR",
    "ifscCode":"ICIC0001235",
    "swiftCode":"ICICINBB",
    "upiId":"rahul@icici"
}

### CREATE eDUCATION
POST http://localhost:4004/odata/v4/employee/Educations
Content-Type: application/json

{
    "employee_ID":"2647f862-950c-48a6-b490-6e65dbf04285",
    "qualification":"Bachelor",
    "degree":"B.Tech",
    "specialization":"Computer Science",
    "institution":"JNTUH",
    "boardUniversity":"JNTUH",
    "country":"India",
    "passingYear":2022,
    "percentage":82,
    "cgpa":8.4,
    "grade":"A"
}

### create experence
POST http://localhost:4004/odata/v4/employee/Experiences
Content-Type: application/json

{
    "employee_ID":"2647f862-950c-48a6-b490-6e65dbf04285",
    "companyName":"Infosys",
    "designation":"Software Engineer",
    "employmentType":"Permanent",
    "joiningDate":"2020-01-01",
    "relievingDate":"2023-12-31",
    "lastSalary":650000,
    "location":"Hyderabad",
    "reasonForLeaving":"Career Growth"
}
### create Document
POST http://localhost:4004/odata/v4/employee/Documents
Content-Type: application/json

{
    "employee_ID":"2647f862-950c-48a6-b490-6e65dbf04285",
    "documentType":"PAN",
    "documentNumber":"ABCDE1234F",
    "fileName":"pan.pdf",
    "mimeType":"application/pdf",
    "fileSize":250000,
    "filePath":"/documents/pan.pdf"
}

### GET STATUTORY 
GET http://localhost:4004/odata/v4/employee/StatutoryDetails


### Statutory Details
POST http://localhost:4004/odata/v4/employee/StatutoryDetails
Content-Type: application/json

{
    "employee_ID":"2647f862-950c-48a6-b490-6e65dbf04285",
    "uanNumber":"100000001",
    "pfNumber":"PF100001",
    "esiNumber":"ESI100001",
    "panNumber":"ABCDE1234F",
    "aadhaarNumber":"123456789012",
    "isPFApplicable":true,
    "isESIApplicable":true
}

